# ============================================
# App
# ============================================
# Site URL (used for canonical URLs, sitemap, etc.)
NEXT_PUBLIC_SITE_URL=https://801outlet.com

# Phone contact (E.164 format)
NEXT_PUBLIC_PHONE_E164=+13852016328

# ============================================
# Database / Auth (Supabase)
# ============================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# Payments (Square Hosted Checkout)
# ============================================
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
SQUARE_WEBHOOK_SIGNATURE_KEY=

# ============================================
# Email (Resend)
# ============================================
RESEND_API_KEY=
EMAIL_FROM=orders@801outlet.com

# ============================================
# Admin
# ============================================
# Comma-separated list of admin emails
ADMIN_ALLOWED_EMAILS=
